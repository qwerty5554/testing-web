REGISTRY=${CI_REGISTRY:-localhost:5050}
TESTING_WEB_TAG=${CI_COMMIT_REF_NAME:-develop}
JAVA_OPTS=${JAVA_OPTS:--Ddebug -Xmx32m}
OTEL_RESOURCE_ATTRIBUTES=service.name=uat-testing-web,service.version=1.0.0
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_COMPRESSION=gzip
OTEL_EXPORTER_OTLP_ENDPOINT=http://10.0.2.15:4318
OTEL_EXPORTER_OTLP_HEADERS="uptrace-dsn=project1_secret"
OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=DELTA
OTEL_EXPORTER_OTLP_METRICS_DEFAULT_HISTOGRAM_AGGREGATION=base2_exponential_bucket_histogram
